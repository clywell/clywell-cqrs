<Project Sdk="Microsoft.NET.Sdk">

  <ItemGroup>
    <!-- Test Framework -->
    <PackageReference Include="xunit" />
    <PackageReference Include="xunit.runner.visualstudio">
      <PrivateAssets>all</PrivateAssets>
      <IncludeAssets>runtime; build; native; contentfiles; analyzers; buildtransitive</IncludeAssets>
    </PackageReference>
    <PackageReference Include="Microsoft.NET.Test.Sdk" />
  </ItemGroup>

  <ItemGroup>
    <!-- Mocking -->
    <PackageReference Include="Moq" />
  </ItemGroup>

  <ItemGroup>
    <!-- Logging (concrete implementation needed for AddProvider in tests) -->
    <PackageReference Include="Microsoft.Extensions.Logging" />
  </ItemGroup>

  <ItemGroup>
    <!-- Code Coverage -->
    <PackageReference Include="coverlet.collector">
      <PrivateAssets>all</PrivateAssets>
      <IncludeAssets>runtime; build; native; contentfiles; analyzers; buildtransitive</IncludeAssets>
    </PackageReference>
  </ItemGroup>

  <ItemGroup>
    <ProjectReference Include="..\..\src\Clywell.Core.Cqrs\Clywell.Core.Cqrs.csproj" />
    <!-- Source generator: referenced as analyzer so it emits handler registration at compile time -->
    <ProjectReference
      Include="..\..\src\Clywell.Core.Cqrs.Generators\Clywell.Core.Cqrs.Generators.csproj"
      OutputItemType="Analyzer"
      ReferenceOutputAssembly="false" />
  </ItemGroup>

  <ItemGroup>
    <!-- Global usings for test files -->
    <Using Include="Xunit" />
  </ItemGroup>

</Project>